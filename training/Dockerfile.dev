# =============================================================================
# Dev Container — T5 Recipe Correction (Interactive)
# =============================================================================
# Purpose:
# - Interactive development (Jupyter/IPython/shell) with build tools available
# - Fast iteration with bind-mounts (code/notebooks/data)
#
# Build:   docker compose build jupyter
# Run:     docker compose up jupyter
# =============================================================================

ARG BASE_IMAGE=python:3.11-slim
FROM ${BASE_IMAGE} AS builder

LABEL maintainer="mlops-class"
LABEL description="T5 recipe correction dev container (interactive)"

# System deps for interactive/dev work
RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        git \
        curl \
        less \
        vim-tiny \
        # libgomp1 is required by some HuggingFace tokenizer backends
        libgomp1 \
    && rm -rf /var/lib/apt/lists/*

# Install uv (same mechanism as training Dockerfile)
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

ENV VIRTUAL_ENV="/opt/venv"
ENV UV_PROJECT_ENVIRONMENT="/opt/venv"
ENV PATH="/opt/venv/bin:$PATH"

WORKDIR /workspace

# Install Python dependencies (cached independently of source changes)
COPY pyproject.toml uv.lock ./
RUN uv sync --frozen --group dev

RUN useradd -m -u 1000 trainer

# Default workspace layout (compose bind-mounts will overlay these)
WORKDIR /workspace

COPY --chown=trainer:trainer pyproject.toml uv.lock ./

# Keep defaults consistent with runtime image
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    TOKENIZERS_PARALLELISM=false \
    HF_HOME=/app/.cache/huggingface \
    TRANSFORMERS_CACHE=/app/.cache/huggingface/hub \
    MLFLOW_TRACKING_URI=http://mlflow:5000 \
    MLFLOW_S3_ENDPOINT_URL=http://minio:9000

# Create expected dirs (helps when volumes aren't mounted yet)
RUN mkdir -p /opt/venv /app/.cache/huggingface /workspace/checkpoints /workspace/data/raw /workspace/data/processed /workspace/notebooks

# Dev default: shell (compose overrides command to Jupyter)
CMD ["bash"]
