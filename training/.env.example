# Copy to .env and adjust. Docker Compose loads .env from this directory automatically.
# Secrets: use strong unique values in production; never commit .env (it is gitignored).

# ── MinIO (S3 API :9000, console :9001) — also used as AWS_* for MLFlow artifacts
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_minio_root_password

# ── PostgreSQL — MLFlow backend store (:5432)
POSTGRES_USER=mlflow
POSTGRES_PASSWORD=changeme_postgres_password
POSTGRES_DB=mlflow

# ── MLflow Host header (DNS rebinding). Compose merges MLflow upstream defaults + mlflow:5000 + extras below.
# Defaults cover private LAN IPs (10/8, 172.16–31, 192.168) and localhost — not public IPs; add those explicitly.
# Add your browser URL host:port (strict match). Use both name and name:port if you use a non-default port mapping.
# MLFLOW_EXTRA_ALLOWED_HOSTS=my.vm.org,my.vm.org:5000,203.0.113.7,203.0.113.7:5000
# Full override (optional): replaces the merged list entirely. Lab only on untrusted networks:
# MLFLOW_SERVER_ALLOWED_HOSTS=*

# ── Jupyter Lab (:8888) — leave empty for a random token (check: docker compose logs jupyter)
JUPYTER_TOKEN=
TORCH_BUILD_MODE=auto

# ── MinIO bucket names (must match buckets created by minio-init in docker-compose)
MINIO_BUCKET_DATASETS=recipe-datasets
MINIO_BUCKET_MODELS=model-registry

# ── Redis — host/port as seen from jupyter/training containers
REDIS_HOST=redis
REDIS_PORT=6379

# ── Training job (used with: docker compose --profile training run --rm training …)
MODEL_NAME=t5-small
MAX_INPUT_LENGTH=512
MAX_TARGET_LENGTH=512
TRAIN_BATCH_SIZE=8
EVAL_BATCH_SIZE=8
NUM_EPOCHS=3
LEARNING_RATE=0.0003
EXPERIMENT_NAME=recipe-correction-t5
