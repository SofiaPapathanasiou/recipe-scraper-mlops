# Copy to .env only when you need local runtime overrides.
# The YAML config files are now the default source of truth for:
# - MLflow tracking URI
# - Accelerate process count
# - Jupyter token default
# - Torch build mode
#
# Example optional overrides:
# MLFLOW_TRACKING_URI=http://192.168.1.11:30800/
# NUM_PROCESSES=1
# JUPYTER_TOKEN=
# TORCH_BUILD_MODE=auto
