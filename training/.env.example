# Copy to .env and adjust. Docker Compose loads .env from this directory automatically.
# Secrets: use strong unique values in production; never commit .env (it is gitignored).

# ── Remote MLflow tracking server
MLFLOW_TRACKING_URI=http://129.114.26.23:8000/

# ── Jupyter Lab (:8888) — leave empty for a random token (check: docker compose logs jupyter)
JUPYTER_TOKEN=
TORCH_BUILD_MODE=auto

# ── Training — set to the number of GPUs/processes to use with Accelerate
NUM_PROCESSES=2
